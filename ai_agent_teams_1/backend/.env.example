# ai_agent_teams_1 Environment Variables

# === Project ===
PROJECT_NAME=ai_agent_teams_1
DEBUG=true
ENVIRONMENT=local
TIMEZONE=UTC  # IANA timezone: UTC, Europe/Warsaw, America/New_York
MODELS_CACHE_DIR=./models_cache

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agent_teams_1

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === API Key Auth ===
API_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# === RAG Configuration ===
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_CHUNKING_STRATEGY=recursive  # recursive, markdown, or fixed
RAG_HYBRID_SEARCH=false  # Enable BM25 + vector hybrid search
RAG_ENABLE_OCR=false  # OCR fallback for scanned PDFs (requires tesseract-ocr installed)
# Vector Database (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=default
MILVUS_TOKEN=root:Milvus
# === PDF Parser Selection ===
# RAG ingestion parser: pymupdf, llamaparse, liteparse
PDF_PARSER=pymupdf
# Chat file attachment parser: pymupdf, llamaparse, liteparse
CHAT_PDF_PARSER=pymupdf
LLAMAPARSE_API_KEY=
LLAMAPARSE_TIER=agentic  # fast, cost_effective, agentic, agentic_plus

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0


# === AI Agent (pydantic_ai, openrouter) ===
OPENROUTER_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4-6
AI_TEMPERATURE=0.7
# Embeddings
# Sentence Transformers (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# Retrieval
RAG_DEFAULT_COLLECTION=documents
RAG_TOP_K=10

# Reranker

# PDF Parser
PDF_PARSER=pymupdf
CHAT_PDF_PARSER=pymupdf
LLAMAPARSE_API_KEY=

# Google Drive (optional, for document ingestion)

# === Messaging Channels ===
# Fernet encryption key for bot token storage — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=
# Telegram: webhook base URL for production (e.g. https://api.yourdomain.com)
# Leave empty to use long-polling mode (recommended for development)
TELEGRAM_WEBHOOK_BASE_URL=
# Slack app credentials — from https://api.slack.com/apps
# Signing secret: Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=
# Bot token: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=
# App-level token: Basic Information → App-Level Tokens (xapp-..., for Socket Mode dev)
SLACK_APP_TOKEN=

# === Email ===
EMAIL_FROM=noreply@ai_agent_teams_1.com
EMAIL_FROM_NAME=ai_agent_teams_1
RESEND_API_KEY=re_xxx

# === Billing (Stripe) ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 1 USD = 1000 credits
CREDITS_PER_USD=1000

# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# === Docker Production (Traefik) ===
# Domain for production deployment
DOMAIN=example.com

# Let's Encrypt email for SSL certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...
# Redis password for production
REDIS_PASSWORD=change-me-in-production
# Flower monitoring credentials
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production
