
# ai_agent_teams_1 - Production Environment
# Generated by fastapi-fullstack v0.2.7
#
# IMPORTANT: Copy this file to .env.prod before deploying
#   cp .env.prod.example .env.prod
#
# WARNING: Never commit .env.prod to version control!

# === Container Prefix (must be unique per server) ===
CONTAINER_PREFIX=ai_agent_teams_1

# === Domain Configuration ===
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # Generate: openssl rand -base64 32
POSTGRES_DB=ai_agent_teams_1

# === Redis ===
REDIS_PASSWORD=  # Generate: openssl rand -base64 32

# === Milvus (RAG Vector Database) ===
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_DATABASE=default

# === JWT Secret ===
SECRET_KEY=  # Generate: openssl rand -hex 32

# === Traefik Dashboard ===
# Generate with: htpasswd -nb admin yourpassword
# Example: admin:$apr1$xyz$hash
TRAEFIK_DASHBOARD_AUTH=

# === Flower Monitoring ===
FLOWER_USER=admin
FLOWER_PASSWORD=  # Generate: openssl rand -base64 16

# === Messaging Channels ===
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=
TELEGRAM_WEBHOOK_BASE_URL=https://api.example.com
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
